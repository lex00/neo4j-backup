# Copy to .env (just does this automatically on `just up`).
# Values marked (verify) are confirmed against Neo4j docs by the config pass.

# Neo4j Enterprise image tag (calendar-versioned, must be >= 2025.01 for current
# discovery). Pin a full patch tag for reproducibility.
NEO4J_VERSION=2026.05.0-enterprise
NEO4J_PASSWORD=devpassword

# Credential source (#18). Default `env` reads NEO4J_PASSWORD above, resolved lazily per
# connect (rotation-friendly). For AWS Secrets Manager, set SECRET_PROVIDER=aws-sm and
# NEO4J_PASSWORD_REF=<secret id/ARN> (optionally `<id>#json_key` to select a JSON field).
# SECRET_PROVIDER=env
# NEO4J_PASSWORD_REF=

# Object storage (MinIO locally). These double as the MinIO root credentials.
BACKUP_BUCKET=neo4j-backups
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Server-side encryption: MinIO built-in KMS stands in for cloud KMS locally (a single
# demo key; per-group keys in prod use cloud KMS, one key/bucket per group).
# Format: <key-name>:<base64 32-byte key>. The bucket default encryption uses the name.
MINIO_KMS_SECRET_KEY=demo-group-key:GMj4rbFZOkQyBNK6HY2gjj5mNHQlrT/B+fYiOe5Ieuo=
KMS_KEY_NAME=demo-group-key

# S3 endpoint override so neo4j-admin AND the Neo4j server (AWS SDK v2) talk to MinIO.
# Confirmed var: AWS_ENDPOINT_URL_S3 (or AWS_ENDPOINT_URL; _S3 is more specific).
AWS_ENDPOINT_URL_S3=http://minio:9000

# seedConfig for Cypher seed-from-URI. Docs enumerate only region=...; the MinIO
# endpoint is set via AWS_ENDPOINT_URL_S3 on the server, not here.
SEED_CONFIG=region=us-east-1

# Backup source: which member's backup port the runner pulls from.
# Single-instance: neo4j:6362. Cluster: prefer a follower/secondary (see compose.cluster.yaml).
NEO4J_BACKUP_SOURCE=neo4j:6362

# Backup runner scratch: neo4j-admin stages the artifact HERE before uploading to S3
# (there is no stream-to-S3 mode). Size to the LARGEST full backup — can be several TB.
# This is a dedicated mounted volume, deliberately NOT the orchestrator's disk.
SCRATCH_PATH=/scratch

# Cap the neo4j-admin JVM heap per backup process (HEAP_SIZE env, confirmed).
RUNNER_HEAP_SIZE=2G
# Page cache for the backup process. MUST be set explicitly: if omitted, neo4j-admin
# inherits the server's pagecache (can be 60%+ of RAM) and OOMs the runner.
RUNNER_PAGECACHE=512M
